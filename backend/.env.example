# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=CareerOS AI
APP_ENV=development        # development | testing | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ─────────────────────────────────────────────────────────────────
# Development: sqlite+aiosqlite:///./careeros.db
# Production:  postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./careeros.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600
REDIS_ENABLED=false        # set to true in production

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── AI Provider ──────────────────────────────────────────────────────────────
AI_PROVIDER=gemini         # gemini | openai
AI_API_KEY=YOUR_AI_API_KEY_HERE
AI_MODEL=gemini-1.5-pro

# ─── File Upload ──────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=uploads

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local     # local | s3 | gcs | azure
STORAGE_BUCKET=careeros-exports
PDF_EXPORT_DIR=uploads/exports

# S3 (only required if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# GCS (only required if STORAGE_PROVIDER=gcs)
GCS_CREDENTIALS_JSON=

# Azure (only required if STORAGE_PROVIDER=azure)
AZURE_STORAGE_CONNECTION_STRING=

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60      # requests per window
RATE_LIMIT_WINDOW=60       # window in seconds
RATE_LIMIT_AUTH=10
RATE_LIMIT_AI=20
RATE_LIMIT_EXPORT=10
RATE_LIMIT_UPLOAD=5

# ─── Email (optional — for future use) ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_ADDRESS=noreply@careeros.ai

# ─── Background Workers ────────────────────────────────────────────────────────
WORKER_CONCURRENCY=4
TASK_TIMEOUT=300

# ─── PDF / Playwright ─────────────────────────────────────────────────────────
PLAYWRIGHT_TIMEOUT=30000

# ─── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=                # optional — leave empty to disable
METRICS_ENABLED=false
