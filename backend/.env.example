# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=CareerOS AI
APP_ENV=development
DEBUG=true

API_V1_PREFIX=/api/v1

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-secure-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/careeros

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── AI Provider ──────────────────────────────────────────────────────────────
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=

# ─── File Upload ──────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=uploads
