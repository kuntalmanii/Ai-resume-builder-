# ─── Environment files ───────────────────────────────────────────────────────
.env
.env.*
!.env.example
frontend/.env.local
backend/.env

# ─── Frontend ─────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/

# ─── Backend ──────────────────────────────────────────────────────────────────
backend/.venv/
backend/venv/
