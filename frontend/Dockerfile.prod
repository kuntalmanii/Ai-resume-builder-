# ──────────────────────────────────────────────────────────────────────────────
# Stage 1: deps — install node_modules (cached layer)
# ──────────────────────────────────────────────────────────────────────────────
FROM node:20-alpine AS deps

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --frozen-lockfile


# ──────────────────────────────────────────────────────────────────────────────
# Stage 2: builder — build the Next.js app
# ──────────────────────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Set build-time API URL (can be overridden via build args)
ARG NEXT_PUBLIC_API_URL=http://backend:8000/api/v1
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

RUN npm run build


# ──────────────────────────────────────────────────────────────────────────────
# Stage 3: runtime — minimal production image
# ──────────────────────────────────────────────────────────────────────────────
FROM node:20-alpine AS runtime

LABEL maintainer="CareerOS AI <engineering@careeros.ai>"
LABEL org.opencontainers.image.title="CareerOS AI Frontend"
LABEL org.opencontainers.image.version="1.0.0"

RUN apk add --no-cache curl

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Non-root user
RUN addgroup -S appgroup && adduser -S appuser -G appgroup

# Copy only the production build artifacts
COPY --from=builder --chown=appuser:appgroup /app/.next/standalone ./
COPY --from=builder --chown=appuser:appgroup /app/.next/static ./.next/static
COPY --from=builder --chown=appuser:appgroup /app/public ./public

USER appuser

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:3000 || exit 1

CMD ["node", "server.js"]
